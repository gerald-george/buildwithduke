{
  "name": "buildwithduke",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter @buildwithduke/web dev",
    "build": "pnpm --filter @buildwithduke/web build",
    "typecheck": "pnpm --filter @buildwithduke/web typecheck",
    "preview": "pnpm --filter @buildwithduke/web preview",
    "deploy:pages": "pnpm build && pnpm --filter @buildwithduke/web deploy:pages"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/db-adapters/*"
  ]
}
