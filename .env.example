# Public client key. The matching secret is configured in Cloudflare Pages.
VITE_TURNSTILE_SITE_KEY=
VITE_PLAUSIBLE_DOMAIN=buildwithduke.pages.dev

# Configure these as encrypted Cloudflare Pages environment variables.
TURNSTILE_SECRET_KEY=
RESEND_API_KEY=
ADMIN_EMAIL=buildwithduke@outlook.com
# SHA-256 digest of the admin password, prefixed with sha256:.
ADMIN_PASSWORD_HASH=
# Generate a long random secret (32+ bytes) for signing admin sessions.
ADMIN_SESSION_SECRET=
# A verified Resend sender, e.g. Duke <hello@your-verified-domain.example>
CONTACT_FROM_EMAIL=

# Microsoft Graph delegated OAuth. Register this callback URI in Microsoft Entra:
# https://buildwithduke.pages.dev/api/admin/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Use "common" for both personal Microsoft accounts and work/school accounts.
MICROSOFT_TENANT_ID=common
# Long random value used to encrypt OAuth tokens before they are stored in D1.
INTEGRATION_ENCRYPTION_KEY=

# Private server-side content automation credentials. Never prefix these with VITE_.
OPENROUTER_API_KEY=
SERPAPI_API_KEY=
# Bearer secret shared with the scheduled GitHub Action.
AUTOBLOG_CRON_SECRET=
