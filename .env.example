# Public client key. The matching secret is configured in Cloudflare Pages.
VITE_TURNSTILE_SITE_KEY=
VITE_PLAUSIBLE_DOMAIN=buildwithduke.pages.dev

# Configure these as encrypted Cloudflare Pages environment variables.
TURNSTILE_SECRET_KEY=
ADMIN_EMAIL=buildwithduke@outlook.com
# SHA-256 digest of the admin password, prefixed with sha256:.
ADMIN_PASSWORD_HASH=
# Generate a long random secret (32+ bytes) for signing admin sessions.
ADMIN_SESSION_SECRET=
# The /exec URL from the Google Apps Script contact relay deployment.
GOOGLE_APPS_SCRIPT_URL=
# A long random value shared only by Cloudflare and Apps Script.
CONTACT_RELAY_SECRET=

# Private server-side content automation credentials. Never prefix these with VITE_.
OPENROUTER_API_KEY=
SERPAPI_API_KEY=
# Bearer secret shared with the scheduled GitHub Action.
AUTOBLOG_CRON_SECRET=
